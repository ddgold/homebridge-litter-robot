	},
	"devDependencies": {
		"@types/node": "^24.0.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.0.0",
		"homebridge": "^2.0.0",
		"prettier": "^3.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0"
	},
	"dependencies": {
		"amazon-cognito-identity-js": "^6.3.16"
